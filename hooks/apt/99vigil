//
// Vigil apt hook: enter/exit maintenance window around package
// transactions. Logic lives in /usr/lib/vigil/apt-{pre,post}.sh --
// keep this config short. apt.conf(5) has no escape syntax for
// embedding " inside "..." strings, so we delegate to scripts.
//
// The `test -x ... || true` wrapper handles:
//   1. First install: apt fires Pre-Invoke BEFORE unpacking the
//      package, so /usr/lib/vigil/apt-pre.sh doesn't exist yet.
//   2. Partial removal: scripts gone but config still present.
//
// Without the guard, apt aborts the transaction with "Sub-process
// returned an error code" -- breaking every apt operation system-wide.

DPkg::Pre-Invoke  { "test -x /usr/lib/vigil/apt-pre.sh  && /usr/lib/vigil/apt-pre.sh  || true"; };
DPkg::Post-Invoke { "test -x /usr/lib/vigil/apt-post.sh && /usr/lib/vigil/apt-post.sh || true"; };
