DPkg::Pre-Invoke { "if [ -x /usr/bin/vigil ]; then /usr/bin/vigil maintenance enter --quiet 2>/dev/null; fi; true"; };
DPkg::Post-Invoke { "if [ ! -x /usr/bin/vigil ]; then logger -t vigil-apt 'vigil binary not found at /usr/bin/vigil; skipping refresh'; true; elif refresh_err=$(/usr/bin/vigil baseline refresh --quiet 2>&1); then /usr/bin/vigil maintenance exit --quiet 2>/dev/null; true; else logger -t vigil-apt \"baseline refresh failed: $refresh_err\"; notify-send -u critical 'Vigil' 'Baseline refresh failed after package transaction. Run vigil doctor to investigate.' 2>/dev/null; /usr/bin/vigil maintenance exit --quiet 2>/dev/null; true; fi"; };
