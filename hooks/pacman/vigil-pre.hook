[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Path
Target = usr/bin/*
Target = usr/sbin/*
Target = usr/lib/*
Target = etc/*
Target = boot/*

[Action]
Description = Vigil Baseline: entering maintenance window...
When = PreTransaction
Exec = /bin/sh -c 'if [ -x /usr/bin/vigil ]; then /usr/bin/vigil maintenance enter --quiet 2>/dev/null; fi; exit 0'
